# Server
# Port to run Colyseus server
PORT=2567
# Environment for server behavior (development/production)
NODE_ENV=development
# Comma-separated web origins allowed for Colyseus matchmaker CORS
# Example: MATCHMAKER_ALLOWED_ORIGINS=https://game.example.com,https://www.game.example.com
MATCHMAKER_ALLOWED_ORIGINS=

# Client
# Colyseus WebSocket endpoint used by Next.js app
NEXT_PUBLIC_COLYSEUS_URL=ws://localhost:2567

# Optional: load test / churn test tuning
RPS_CHURN_CYCLES=2
RPS_CHURN_CONCURRENCY=2
RPS_CHURN_SEED=42
RPS_CHURN_TEST_TIMEOUT_MS=90000
RPS_CHURN_NORMAL_CYCLES=8
RPS_CHURN_ABRUPT_RESULT_CYCLES=6
RPS_CHURN_ABRUPT_CHOOSING_CYCLES=6
RPS_CHURN_CONVERGENCE_TIMEOUT_MS=12000
RPS_CHURN_CONVERGENCE_POLL_MS=100
RPS_CHURN_CONVERGENCE_COOLDOWN_MS=1400
RPS_CHURN_MAX_HEAP_DELTA_BYTES=50331648
RPS_CHURN_MAX_RSS_DELTA_BYTES=100663296
RPS_CHURN_MAX_HANDLE_DELTA=10
RPS_CHURN_MAX_HEAP_RATIO=2.5
RPS_CHURN_MAX_RSS_RATIO=1.8
RPS_CHURN_MAX_HANDLE_RATIO=1.8
