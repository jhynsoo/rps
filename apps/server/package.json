{
  "private": true,
  "name": "server",
  "version": "1.0.0",
  "description": "RPS game server powered by Colyseus",
  "main": "build/index.js",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx watch src/index.ts",
    "start:once": "tsx src/index.ts",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "loadtest": "tsx loadtest/example.ts --room my_room --numClients 2",
    "loadtest:ci": "tsx loadtest/ci.ts",
    "build": "npm run clean && tsc",
    "check-types": "tsc --noEmit",
    "clean": "rimraf build",
    "test": "mocha -r tsx test/**_test.ts --exit --timeout 15000"
  },
  "license": "UNLICENSED",
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@colyseus/loadtest": "^0.16.0",
    "@colyseus/testing": "^0.16.0",
    "@types/express": "^4.17.1",
    "@types/mocha": "^10.0.1",
    "mocha": "^10.2.0",
    "rimraf": "^5.0.0",
    "tsx": "^4.10.2",
    "typescript": "^5.0.4"
  },
  "dependencies": {
    "@colyseus/monitor": "^0.16.0",
    "@colyseus/playground": "^0.16.0",
    "@colyseus/schema": "^3.0.76",
    "colyseus.js": "^0.16.0",
    "@colyseus/tools": "^0.16.0",
    "@rps/contracts": "workspace:*",
    "colyseus": "^0.16.0",
    "express": "^4.18.2"
  }
}
